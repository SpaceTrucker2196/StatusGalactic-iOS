# Xcode (generated by xcodegen from project.yml)
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
build/
*.ipa
*.dSYM.zip
*.dSYM
.build/

# Swift Package Manager
Packages/
Package.pins
Package.resolved
.swiftpm/

# Xcode Cloud needs a committed Package.resolved because it disables
# SPM auto-resolution for reproducibility. .xcodeproj/ is regenerated
# per clone, so we keep the canonical copy here and ci_post_clone.sh
# stages it into the generated workspace.
!ci_scripts/Package.resolved

# macOS
.DS_Store

# Secrets / local
.env
.env.*
!.env.example
local.xcconfig
Secrets.plist

# Editor
.vscode/
.idea/
*.swp

# Generated marketing screenshots (re-rendered from simulator runs)
marketing/screenshots/
